# JWT Configuration
JWT_SECRET=super-secret-key-change-this-in-production

# Admin Credentials (bcrypt hashed)
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2b$10$wMH58x6AUTUQbaH309oA3.HFLEoZZnSNevS0wx1AE8GYiOz5V6PiK

# Server Port
PORT=3000

# Database Configuration (Optional but recommended)
# For local development with PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/config_manager

# For Render.com: Add DATABASE_URL from your PostgreSQL service
# DATABASE_URL=postgresql://neondb_owner:password@ep-example.eu-west-2.aws.neon.tech/neondb?sslmode=require

# If DATABASE_URL is not set, the server will work with filesystem-based storage
# (configs stored in deployed_configs/ directory)
